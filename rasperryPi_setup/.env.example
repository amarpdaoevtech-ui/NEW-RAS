# DAO EV Tech - Environment Configuration
# Copy this file to .env and modify as needed

# Active bike model (must match a key in config/bike_models.json)
BIKE_MODEL=703-O

# Database settings
DB_PATH=data/bms_data.db
DB_LOG_INTERVAL=5

# Server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
DEBUG_MODE=False

# Serial port override (optional - will use config if not set)
# SERIAL_PORT=/dev/ttyAMA0
# BAUD_RATE=9600

# Data retention (days)
DATA_RETENTION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bms_server.log
